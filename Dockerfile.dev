# Dockerfile de développement pour Next.js
# Optimisé pour le hot-reload et la DX locale
FROM node:20-alpine

WORKDIR /app

# Installer les dépendances système utiles (sharp pour les images, etc.)
RUN apk add --no-cache libc6-compat

# Copier uniquement les fichiers de dépendances en premier
# (layer cache : ne réinstalle que si package.json change)
COPY package.json package-lock.json* yarn.lock* pnpm-lock.yaml* ./

# Installer les dépendances
RUN \
  if [ -f yarn.lock ]; then yarn install --frozen-lockfile; \
  elif [ -f package-lock.json ]; then npm ci; \
  elif [ -f pnpm-lock.yaml ]; then corepack enable pnpm && pnpm install --frozen-lockfile; \
  else npm install; \
  fi

# Copier le reste du code source
COPY . .

# Exposer le port Next.js
EXPOSE 3000

# Démarrer en mode développement avec hot-reload
CMD ["npm", "run", "dev"]